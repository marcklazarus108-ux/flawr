# URL of your deployed backend's API, including /api
# Local dev default: http://localhost:4000/api
VITE_API_URL=http://localhost:4000/api

# Google OAuth Client ID (same project as backend's GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# WebSocket URL of the real-time collaboration server (separate from the
# main API). Local dev default: ws://localhost:1234
# Once deployed on Render, use wss:// (not ws://) plus its Render URL.
VITE_COLLAB_URL=ws://localhost:1234
