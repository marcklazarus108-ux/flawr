# Postgres connection string from Neon (or any Postgres host)
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Long random string used to sign login sessions. Generate one at
# https://generate-secret.vercel.app/32 and paste it here.
JWT_SECRET=

# From Google Cloud Console > APIs & Services > Credentials
# (OAuth 2.0 Client ID, type: Web application)
GOOGLE_CLIENT_ID=

# Gemini API key from https://aistudio.google.com/apikey
# Not used yet in Phase 1, but the app expects this variable to exist.
GEMINI_API_KEY=

# The URL your frontend is deployed at, used for CORS.
# Example: https://flawr-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Port the backend server runs on (Render sets this automatically in production)
PORT=4000

# Port the real-time collaboration server runs on. This runs as its own
# separate process/service (npm run collab) - see the README.
COLLAB_PORT=1234
